# =============================================================================
# VidU backend — copy to `.env` and fill in values. Never commit real secrets.
# =============================================================================
# Many keys are OPTIONAL: the app reads defaults from `src/config/*.ts` and
# `src/lib/env.ts`. Only set an env var when you need to override or enable a feature.

# --- Core (required) ---
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vidu?schema=public

# --- CORS — comma-separated browser origins allowed to call this API ---
# Order matters for OAuth: the FIRST URL is where TikTok/Meta redirects after linking (`oauth.controller`).
# Production example (marketing site + app; apex/www pairs are auto-expanded per hostname):
#   FRONTEND_URL=https://www.app.vid-u.com,https://www.vid-u.com
FRONTEND_URL=http://localhost:5173

# Auth/OAuth flow logs (Google start, callback, GET /me 401, sign-out) are always emitted at info/warn.

# --- Supabase Auth (required for login / JWT routes) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# SUPABASE_JWT_SECRET — only if your project issues HS256 JWTs (some local/emulator setups).
# If unset, the API verifies RS256 using JWKS (see next line).
# SUPABASE_JWT_SECRET=

# SUPABASE_JWKS_URL — only if JWKS is not at the default `${SUPABASE_URL}/auth/v1/.well-known/jwks.json`.
# SUPABASE_JWKS_URL=

# --- Session cookie (httpOnly `vidu_session`; SPA uses credentials: include) ---
# AUTH_COOKIE_SAME_SITE=lax

# --- Public API URL (OAuth redirect_uri); defaults to http://localhost:${PORT} ---
PUBLIC_API_URL=http://localhost:3001

# --- Xendit (required when testing invoices / payouts / webhooks) ---
XENDIT_SECRET_KEY=
# Callback verification token — must match the token set on each Xendit webhook URL.
# In Xendit Dashboard → Webhooks, add the SAME API URL for both products, e.g.:
#   https://YOUR-API/webhooks/xendit
# (use ngrok/cloudflared to expose localhost:3001 in local dev)
#
# Required webhook products (both → that URL + this token):
#   • INVOICES — invoice paid (PAID); funds campaigns (external_id prefix fund_)
#   • DISBURSEMENT — Payouts v2 succeeded / failed; creator payouts + brand refunds
#
# Do NOT rely on Payment Requests v2 alone for checkout — VidU uses POST /v2/invoices.
#
# xenPlatform: API key needs **Account Write**, **Split Rule** write, plus invoice/payout permissions.
# One Owned sub-account per brand is provisioned at campaign create / checkout.
# Deposits: master invoice + split rule (85% brand pool → sub-account, 15% platform on master).
# Payouts/refunds use `for-user-id` on the brand sub-account when LIVE.
XENDIT_MASTER_USER_ID=
# Webhook products on POST /webhooks/xendit:
#   INVOICES, DISBURSEMENT, xenPlatform account.created, split.payment (split status)
XENDIT_WEBHOOK_TOKEN=

# --- TikTok / Meta OAuth (optional until connect flows are used) ---
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# TikTok Login Kit does not accept http://localhost redirect URIs — use an HTTPS tunnel to your API, e.g.:
#   ngrok http 3001
# Register the same URL in TikTok Developer Portal → Login Kit → Redirect URI.
TIKTOK_REDIRECT_URI=https://YOUR-SUBDOMAIN.ngrok-free.app/oauth/tiktok/callback
# Public API origin (OAuth redirect_uri base when TIKTOK_REDIRECT_URI is unset). Match your tunnel in local dev.
PUBLIC_API_URL=https://YOUR-SUBDOMAIN.ngrok-free.app

META_APP_ID=
META_APP_SECRET=
# Meta does not allow localhost in App Domains — use the same HTTPS tunnel as TikTok (not localhost):
META_REDIRECT_URI=https://YOUR-SUBDOMAIN.ngrok-free.app/oauth/facebook/callback
# Default (Facebook Login app): public_profile,user_videos,user_posts
# Page-only Meta app: public_profile,pages_show_list,pages_read_engagement,read_insights
# META_OAUTH_SCOPES=public_profile,user_videos,user_posts

# --- OAuth state signing (min 32 chars); falls back to first 32 bytes of TOKEN_ENCRYPTION_KEY hex if unset ---
OAUTH_STATE_SECRET=change-me-32-chars-minimum-ok!!

# --- Token + payment encryption (64 hex chars); required in production for platform tokens ---
TOKEN_ENCRYPTION_KEY=

# --- Cloudflare R2 (S3 API) — optional; without all four, POST /uploads/presign returns 503 ---
# R2_S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
# R2_BUCKET=vidu-private
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# Public CDN / R2 custom domain (optional; no trailing slash). Uncomment when objects are served at a stable HTTPS origin.
# PUBLIC_OBJECT_BASE_URL=https://cdn.example.com

# --- Admin HTTP Basic (optional; empty password → /admin/* returns 403 “not configured”) ---
ADMIN_BASIC_USER=admin
ADMIN_BASIC_PASSWORD=

# =============================================================================
# Optional overrides — defaults live in src/config/read-env.ts, fees.ts,
# campaign-limits.ts, uploads-r2.ts, src/lib/env.ts (META_GRAPH_VERSION, etc.)
# Uncomment only when you need non-default behaviour.
# =============================================================================
# PLATFORM_DEPOSIT_FEE_PERCENT=0.15
# CREATOR_PAYOUT_FEE_PERCENT=0.2
# MIN_PUBLISH_PHP=10000
# MIN_BRAND_RATE_PER_1K=35
# UPLOAD_PRESIGN_EXPIRES_SEC=900
# UPLOAD_MAX_BYTES=15728640
# META_GRAPH_VERSION=v21.0
