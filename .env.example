NODE_ENV=development
PORT=3001

DATABASE_URL="postgresql://postgres:postgres@localhost:5434/vidu_waitlist?schema=public"

# --- CORS — comma-separated browser origins allowed to call this API ---
# Order matters for OAuth: the FIRST URL is where TikTok/Meta redirects after linking (`oauth.controller`).
# Production example (marketing site + app; apex/www pairs are auto-expanded per hostname):
#   FRONTEND_URL=https://www.app.vid-u.com,https://www.vid-u.com
FRONTEND_URL=http://localhost:5173
