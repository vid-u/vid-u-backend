# Copy to .env and fill in values. Never commit .env.

# Supabase Postgres — use the connection string from Project Settings → Database.
# For local Prisma CLI (migrate, generate), use a URL that can reach Postgres (often the "direct" host).
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

NODE_ENV=development
PORT=3001

# Comma-separated browser origins for CORS (Vite default: http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# Supabase — for verifying user JWTs in protected routes (Project Settings → API)
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional: protect POST /jobs/check-expired
# CRON_SECRET=

# Resend — https://resend.com/api-keys (replace re_xxxxxxxxx with your real API key)
RESEND_API_KEY=re_xxxxxxxxx
# Must match a domain verified in Resend (exact host). If you verified contact.example.com, use e.g. no-reply@contact.example.com — not no-reply@example.com until that root domain is verified too.
# Bare email gets display name "Franz from BugHyve" in the inbox; use "Your Name <addr>" to override.
RESEND_FROM_EMAIL=onboarding@resend.dev
# Optional: absolute URL to logo for HTML emails. If unset, uses first FRONTEND_URL origin + /email-logo.svg (see landing public/email-logo.svg).
# EMAIL_LOGO_URL=https://your-site.com/email-logo.svg

# Cloudflare R2 (S3 API) — presigned uploads; see docs/cloudflare-r2.md
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# Public URL for avatars & client logos (no trailing slash), e.g. https://pub.example.com or R2 public URL
# R2_PUBLIC_BASE_URL=
