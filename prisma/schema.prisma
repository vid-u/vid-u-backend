generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WaitlistRole {
  brand
  creator
}

model Waitlist {
  id        String       @id @default(uuid()) @db.Uuid
  email     String       @unique
  role      WaitlistRole
  notes     String?
  createdAt DateTime     @default(now()) @map("created_at")

  @@map("waitlist")
}
